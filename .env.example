# RAG Refinement System - environment template.
# Copy to .env and fill in real values locally. NEVER commit a populated .env.
# All values below are placeholders only - no real secrets belong in this file.
# Secrets are injected at runtime via a secret manager in deployed environments
# (12-factor, AGREED CONTRACT devops <-> all implementers; NFR-007).

# --- LLM / embedding / rerank providers ---
OPENAI_API_KEY=replace-with-openai-key
ANTHROPIC_API_KEY=replace-with-anthropic-key
COHERE_API_KEY=replace-with-cohere-key

# --- Observability ---
LANGSMITH_API_KEY=replace-with-langsmith-key

# --- Data stores ---
# Postgres structure store (ADR-10) and Qdrant vector store (ADR-2).
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag
QDRANT_URL=http://localhost:6333

# --- Auth / crypto (ADR-7) ---
JWT_SECRET=replace-with-jwt-signing-secret
API_KEY_SALT=replace-with-api-key-salt

# --- Local compose convenience (optional) ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
