<mxfile host="app.diagrams.net" type="device">
  <diagram id="component_diagram" name="Component Diagram">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="spa" value="Personal Tool SPA&#10;React + Tailwind + Vite" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ent" value="Enterprise RAG client" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="160" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="sys" value="RAG Refinement System" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="280" y="20" width="540" height="540" as="geometry"/>
        </mxCell>
        <mxCell id="api" value="API Gateway&#10;[FastAPI async]" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="20" y="40" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ing" value="Ingestion Service" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="20" y="130" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="router" value="Router Node&#10;Claude 3 Haiku" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="200" y="40" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="ret" value="Retrieve Nodes&#10;targeted + fallback" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="200" y="130" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="rerank" value="Rerank Node&#10;Cohere Rerank-3" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="200" y="220" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="gen" value="Generate Node&#10;Claude / GPT-4o" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="380" y="130" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="cache" value="TOC Cache (LRU)" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="380" y="40" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="comp" value="Compliance Handlers&#10;erasure / access" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="sys">
          <mxGeometry x="20" y="220" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pg" value="PostgreSQL&#10;documents, sections" style="shape=cylinder3;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="600" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="qd" value="Qdrant / ChromaDB&#10;chunk vectors" style="shape=cylinder3;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="600" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="obj" value="Object Storage&#10;raw uploads" style="shape=cylinder3;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="600" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="prov" value="External Providers: Anthropic | OpenAI | Cohere | Azure Doc Intelligence | LangSmith" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="280" y="700" width="540" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ce1" style="endArrow=open;html=1;" edge="1" parent="1" source="spa" target="api"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce2" style="endArrow=open;html=1;" edge="1" parent="1" source="ent" target="api"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce3" style="endArrow=open;html=1;" edge="1" parent="sys" source="api" target="router"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce4" style="endArrow=open;html=1;" edge="1" parent="sys" source="api" target="ing"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce5" style="endArrow=open;html=1;" edge="1" parent="sys" source="api" target="comp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce6" style="endArrow=open;html=1;" edge="1" parent="sys" source="router" target="cache"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce7" style="endArrow=open;html=1;" edge="1" parent="sys" source="router" target="ret"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce8" style="endArrow=open;html=1;" edge="1" parent="sys" source="ret" target="rerank"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce9" style="endArrow=open;html=1;" edge="1" parent="sys" source="rerank" target="gen"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="note" value="Invariant: Router Node never calls Generate Node for /v1/route (HLD 7.2). Mermaid source: uml/component_diagram.md" style="text;html=1;align=left;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="760" width="780" height="20" as="geometry"/>
